{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TRAP21: Test with Docker",
      "type": "shell",
      "command": "docker build --target test -t trap21:test .",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "TRAP21: Build runtime image",
      "type": "shell",
      "command": "docker build --target runtime -t trap21:latest .",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "TRAP21: Test with local JDK",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test.ps1",
      "group": "test",
      "problemMatcher": ["$javac"]
    }
  ]
}
