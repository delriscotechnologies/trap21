# Host interface published by Docker Compose. Localhost is the safe default.
# Set both values explicitly for an authorized remote deployment.
TRAP21_LISTEN_HOST=127.0.0.1
TRAP21_PUBLIC_HOST=127.0.0.1

# Defensive resource limits.
TRAP21_MAX_UPLOAD_BYTES=10485760
TRAP21_MAX_QUARANTINE_BYTES=268435456
TRAP21_MAX_QUARANTINE_FILES=4096
TRAP21_RETENTION_DAYS=30
TRAP21_MAX_EVENT_LOG_BYTES=33554432
TRAP21_MAX_EVENT_ARCHIVES=5
TRAP21_MAX_SESSIONS=64
TRAP21_MAX_SESSIONS_PER_IP=8
TRAP21_COMMAND_TIMEOUT=15
